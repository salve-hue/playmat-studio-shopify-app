{% comment %}
  Playmat Studio — App Block
  Replaces: playmat-designer-v1.7.1.liquid (hand-edited theme snippet)

  This block is served by the Playmat Studio Shopify app (Theme App Extension).
  Merchants add it via the Theme Editor on any product section.

  Configuration is managed in the app admin (Railway backend) — no more
  editing Liquid code to update Worker URLs, product maps, or overlay lists.

  Schema settings still available here:
    app_url            — Railway app base URL (set once at install)
    trigger_variant    — Option 1 text that shows the designer
    landing_padding    — Top/bottom padding for the landing button area
    size_variant_keyword — keyword to detect Extended mat variant
{% endcomment %}

{%- liquid
  assign app_url           = section.settings.app_url | default: ''
  assign trigger_variant   = section.settings.trigger_variant | default: ''
  assign landing_padding   = section.settings.landing_padding | default: 10
  assign size_kw           = section.settings.size_variant_keyword | default: ''
  assign shop_domain       = shop.permanent_domain
-%}

{{ 'playmat-designer.css' | asset_url | stylesheet_tag }}

<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Cinzel:wght@400;700&family=Dancing+Script:wght@400;700&family=Oswald:wght@400;700&family=Pacifico&family=Permanent+Marker&family=Press+Start+2P&family=Roboto:wght@400;500;600;700&family=Shadows+Into+Light&display=swap" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/@imgly/background-removal@1.4.3/dist/browser/umd/index.min.js" defer></script>

{%- comment %} Pass Liquid values to JS before any other script runs {%- endcomment %}
<script>
  window.PLAYMAT_APP_URL         = {{ app_url | json }};
  window.PLAYMAT_SHOP            = {{ shop_domain | json }};
  window.PLAYMAT_TRIGGER_VARIANT = {{ trigger_variant | json }};
  window.PLAYMAT_LANDING_PADDING = {{ landing_padding | json }};
  window.PLAYMAT_SIZE_KW         = {{ size_kw | json }};
  window.PLAYMAT_PRODUCT_ID      = {{ product.id | json }};
</script>

{{ 'playmat-designer-bootstrap.js' | asset_url | script_tag }}

