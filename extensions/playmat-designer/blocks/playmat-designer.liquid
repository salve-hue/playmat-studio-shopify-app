                        <option value="project_1_14">Project Points 1-14</option>
                        <option value="lunar">Lunar Points</option>
                        <option value="lunar_1_14">Lunar Points 1-14</option>
                        <option value="khasino">Khasino Points</option>
                    </select>
                </div>
                <div id="color-wrap" class="hidden-field" style="margin-top:10px;">
                    <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px; font-weight:bold; text-transform:uppercase;">Zone Color</label>
                    <div class="inner-panel" style="display:flex; gap:10px; align-items:center; padding:10px; margin-bottom:0;">
                        <div style="flex:0 0 auto;">
                            <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:4px;">Solid</label>
                            <input type="color" id="zone-col" value="#ffffff" oninput="window.syncHex('zone-col','zone-col-hex'); window.renderLayout()" class="color-swatch" style="width:50px;">
                        </div>
                        <div style="flex:1;">
                            <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:4px;">Hex</label>
                            <input type="text" id="zone-col-hex" value="#ffffff" oninput="window.syncColor('zone-col-hex','zone-col'); window.renderLayout()" class="ui-select" style="padding:8px; font-size:13px;">
                        </div>
                    </div>
                    <div id="gradient-wrap" class="hidden-field" style="margin-top:10px;">
                        <div class="inner-panel" style="padding:10px; margin-bottom:0;">
                            <div style="display:flex; gap:10px; align-items:center; margin-bottom:8px;">
                                <div style="flex:1;">
                                    <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:4px;">Color 2</label>
                                    <input type="color" id="zone-col2" value="#000000" oninput="window.syncHex('zone-col2','zone-col2-hex'); window.renderLayout()" class="color-swatch" style="width:50px;">
                                </div>
                                <div style="flex:1;">
                                    <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:4px;">Hex</label>
                                    <input type="text" id="zone-col2-hex" value="#000000" oninput="window.syncColor('zone-col2-hex','zone-col2'); window.renderLayout()" class="ui-select" style="padding:8px; font-size:13px;">
                                </div>
                            </div>
                            <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Gradient Angle</label>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <input type="range" id="gradient-angle" min="0" max="360" value="0" oninput="window.renderLayout()" style="flex:1;">
                                <span id="gradient-angle-val" style="font-size:12px; width:30px; text-align:right; color:var(--brand-text-pri);">0°</span>
                            </div>
                        </div>
                    </div>
                    <div class="toggle-wrap" style="margin-top:10px;">
                        <label class="switch"><input type="checkbox" id="gradient-toggle" onchange="window.toggleGradient()"><span class="slider"></span></label>
                        <span class="toggle-label">Use Gradient</span>
                    </div>
                    <div class="toggle-wrap">
                        <label class="switch"><input type="checkbox" id="opacity-toggle" onchange="window.toggleZoneOpacity()"><span class="slider"></span></label>
                        <span class="toggle-label">Hide Zone Overlay</span>
                    </div>
                </div>
            </div>

            <button class="acc-btn" onclick="window.toggleAcc('acc-ai')">AI TOOLS <span>▼</span></button>
            <div id="acc-ai" class="acc-content">
                <div class="inner-panel">
                    <span class="panel-title">AI FRAME BREAK</span>
                    <button id="ai-bg-btn" class="action-btn btn-secondary" style="border:1px solid var(--brand-hover); color:var(--brand-hover); line-height:1.2;" onclick="window.confirmFrameBreak()">
                        🖼️ REMOVE BACKGROUND <span class="beta-badge">BETA</span>
                    </button>
                    <div id="fg-controls" class="hidden-field" style="margin-top:10px;">
                        <div style="display:flex; gap:8px; margin-bottom:10px;">
                            <button class="action-btn btn-secondary" style="flex:1; margin:0; font-size:11px;" onclick="window.toggleFgVisibility()">SHOW/HIDE FG</button>
                            <button class="action-btn btn-secondary" style="flex:1; margin:0; font-size:11px; background:var(--danger-red)!important; border-color:var(--danger-red)!important;" onclick="window.clearFg()">CLEAR FG</button>
                        </div>
                        <div class="slider-row" style="margin-top:0;">
                            <label>Foreground Position X</label>
                            <input type="range" id="fg-x" min="-200" max="200" value="0" oninput="window.moveFg()">
                            <label style="margin-top:10px;">Foreground Position Y</label>
                            <input type="range" id="fg-y" min="-200" max="200" value="0" oninput="window.moveFg()">
                            <label style="margin-top:10px;">Foreground Scale</label>
                            <input type="range" id="fg-scale" min="0.5" max="2" step="0.01" value="1" oninput="window.scaleFg()">
                        </div>
                    </div>
                </div>
                <div class="inner-panel">
                    <span class="panel-title">ERASER</span>
                    <button id="eraser-toggle-btn" class="action-btn btn-secondary btn-eraser" onclick="window.toggleMaskMode()">ENABLE ERASER</button>
                    <div id="eraser-controls" class="hidden-field" style="margin-top:10px;">
                        <div style="display:flex; gap:10px; margin-bottom:10px;">
                            <div style="flex:1;">
                                <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Brush Size</label>
                                <input type="range" id="eraser-size" min="5" max="200" value="40" oninput="window.updateBrushSize()" style="width:100%;">
                            </div>
                            <div>
                                <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Shape</label>
                                <select id="brush-shape" class="ui-select" style="padding:8px; font-size:12px;" onchange="window.updateBrushShape()">
                                    <option value="round">Round</option>
                                    <option value="square">Square</option>
                                </select>
                            </div>
                        </div>
                        <div style="display: flex; gap: 8px;">
                            <button class="action-btn btn-secondary" style="flex:1; margin:0;" onclick="window.undoErase()">UNDO</button>
                            <button class="action-btn btn-secondary" style="flex:1; margin:0;" onclick="window.resetErase()">RESET</button>
                        </div>
                    </div>
                </div>
                <div class="inner-panel">
                    <span class="panel-title">ZONE RECOLORING</span>
                    <button id="recolor-toggle-btn" class="action-btn btn-secondary btn-recolor" onclick="window.toggleRecolorMode()">ENABLE RECOLOR BRUSH</button>
                    <div id="recolor-controls" class="hidden-field">
                        <div style="display:flex; gap:10px; margin-bottom:10px; margin-top:10px;">
                            <div style="flex:1;">
                                <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Brush Size</label>
                                <input type="range" id="recolor-size" min="5" max="100" value="30" oninput="window.updateRecolorBrush()" style="width:100%;">
                            </div>
                            <div>
                                <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Paint Color</label>
                                <input type="color" id="recolor-color" value="#ff0000" class="color-swatch" style="width:50px; height:30px;" oninput="window.updateRecolorBrush()">
                            </div>
                        </div>
                        <div style="display: flex; gap: 8px;">
                            <button class="action-btn btn-secondary" style="flex:1; margin:0;" onclick="window.undoRecolor()">UNDO</button>
                            <button class="action-btn btn-secondary" style="flex:1; margin:0;" onclick="window.resetRecolor()">RESET</button>
                        </div>
                    </div>
                </div>
            </div>

            <button class="acc-btn" onclick="window.toggleAcc('acc-art')">ADJUSTMENTS <span>▼</span></button>
            <div id="acc-art" class="acc-content">
                <div class="inner-panel">
                    <span class="panel-title">PRINT COLOR CORRECTION</span>
                    <p style="font-size:11px; color:var(--brand-text-sec); line-height:1.4; margin-bottom:15px; margin-top:0;">
                        Images on digital screens look much brighter than physical ink. Use Auto-Optimize to calibrate your art for printing!
                    </p>
                    <button id="auto-opt-btn-adv" class="action-btn btn-secondary" style="border: 1px solid var(--brand-hover); color: var(--brand-hover); margin-bottom:15px;" onclick="window.autoOptimizePrintAdv()">🪄 AUTO-OPTIMIZE FOR PRINT</button>
                    <div class="slider-row" style="margin-top:0;">
                        <label>Brightness</label>
                        <input type="range" id="filter-brightness" min="-0.3" max="0.3" step="0.01" value="0" oninput="window.updateFilters()">
                        <label style="margin-top:10px;">Contrast</label>
                        <input type="range" id="filter-contrast" min="-0.3" max="0.3" step="0.01" value="0" oninput="window.updateFilters()">
                        <label style="margin-top:10px;">Saturation</label>
                        <input type="range" id="filter-saturation" min="-0.5" max="0.5" step="0.01" value="0" oninput="window.updateFilters()">
                    </div>
                    <button class="action-btn btn-secondary" style="margin-top:15px; font-size:11px; padding:8px;" onclick="window.resetFilters()">RESET COLORS</button>
                </div>
                <div class="slider-row">
                    <label>Art Scale</label>
                    <input type="range" id="zoom-in" min="0.1" max="2.5" step="0.01" value="1" oninput="window.handleZoom(this.value)" style="width:100%;">
                    <button class="action-btn btn-secondary" style="margin-top:15px;" onclick="window.forceFit()">RESET ART SCALE & CENTER</button>
                </div>
                <hr style="border:0; border-top:1px solid rgba(255,255,255,0.1); margin:20px 0;">
                <div class="inner-panel">
                    <span class="panel-title">TEXT & TRANSFORMATIONS</span>
                    <button class="action-btn" style="background: var(--brand-hover); margin-bottom:15px;" onclick="window.addAdvText()">+ ADD TEXT</button>
                    <div id="adv-text-tools" class="hidden-field" style="background:rgba(0,0,0,0.3); padding:15px; border-radius:6px; border: 1px solid rgba(255,255,255,0.05); margin-bottom:15px;">
                        <select id="adv-font-family" class="ui-select" onchange="window.updateAdvTextAttr('fontFamily', this.value)">
                            <option value="Rubik">Rubik</option>
                            <option value="Bangers">Bangers</option>
                            <option value="Oswald">Oswald</option>
                            <option value="Permanent Marker">Marker</option>
                            <option value="Cinzel">Cinzel</option>
                            <option value="Pacifico">Pacifico</option>
                        </select>
                        <label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Font Size</label>
                        <input type="range" id="adv-text-size-in" min="10" max="200" value="40" oninput="window.updateAdvTextAttr('fontSize', parseInt(this.value, 10))" style="width:100%; margin-bottom:15px;">
                        <div style="display:flex; gap:10px;">
                            <div style="flex:1;"><label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Fill</label><input type="color" id="adv-text-col" class="color-swatch" value="#ffffff" oninput="window.updateAdvTextAttr('fill', this.value)"></div>
                            <div style="flex:1;"><label style="font-size:11px; color:var(--brand-text-sec); display:block; margin-bottom:5px;">Outline</label><input type="color" id="adv-text-stroke" class="color-swatch" value="#000000" oninput="window.updateAdvTextAttr('stroke', this.value)"></div>
                        </div>
                        <button class="action-btn" style="background:var(--danger-red); margin-top:15px;" onclick="window.removeAdvActive()">DELETE SELECTED</button>
                    </div>
                    <div style="display:flex; gap:8px; margin-bottom: 15px;">
                        <button class="action-btn btn-secondary" style="flex:1; margin:0;" onclick="window.transformActive('rotate')">ROTATE 90°</button>
                        <button class="action-btn btn-secondary" style="flex:1; margin:0;" onclick="window.transformActive('flipX')">FLIP H</button>
                        <button class="action-btn btn-secondary" style="flex:1; margin:0;" onclick="window.transformActive('flipY')">FLIP V</button>
                    </div>
                    <div style="display:flex; gap:10px; align-items:center; margin-bottom: 15px;">
                        <input type="range" id="transform-rotation" min="-180" max="180" value="0" oninput="window.transformActive('angle', this.value)" style="flex:1;">
                        <span id="rotation-val" style="font-size: 13px; width: 35px; text-align: right; color:var(--brand-text-pri);">0°</span>
                    </div>
                    <button class="action-btn btn-secondary" style="margin:0;" onclick="window.transformActive('angle', 0)">RESET ROTATION</button>
                </div>
                <hr style="border:0; border-top:1px solid rgba(255,255,255,0.1); margin:20px 0;">
                <button class="action-btn btn-secondary" style="margin-top:10px;" onclick="window.toggleAdvGuides()">SHOW/HIDE PRINT GUIDES</button>
            </div>

            <div style="flex-grow: 1;"></div>

            <div style="padding: 20px; border-top: 1px solid rgba(255,255,255,0.1);">
                <div id="adv-bleed-warning" class="bleed-warning-banner">
                    ⚠️ Artwork does not cover the full canvas. White borders will appear on your printed mat.<br>
                    Scale your artwork to fill the entire canvas including the red bleed area.
                </div>
                <button id="sidebar-atc" class="action-btn" style="height: 60px; width: 100%; font-size: 16px;" onclick="window.submitToCart('adv')">ADD TO CART</button>
                <div style="text-align:center; padding-top: 15px;">
                    <span class="disclaimer-text">All trademarks and copyrights are owned by their respective owners. We make no claim to ownership of their intellectual property.</span>
                </div>
            </div>
        </div>

        <div id="canvas-column">
            <div id="zoom-toolbar">
                <span style="color: var(--brand-text-sec); font-size: 12px; font-weight:bold; letter-spacing:1px; margin-right: 5px;">VIEW:</span>
                <button class="action-btn btn-secondary" style="margin:0; padding: 6px 14px; font-size:16px; width:auto;" onclick="window.workspaceZoom(0.1)">+</button>
                <button class="action-btn btn-secondary" style="margin:0; padding: 6px 14px; font-size:16px; width:auto;" onclick="window.workspaceZoom(-0.1)">-</button>
                <button class="action-btn btn-secondary" style="margin:0; padding: 6px 12px; width:auto;" onclick="window.workspaceZoom(0)">RESET</button>
            </div>
            <div id="canvas-wrapper">
                <canvas id="main-canvas"></canvas>
                <canvas id="layout-canvas" style="position: absolute; top: 0; left: 0; pointer-events: none; z-index: 10; opacity: 1;"></canvas>
                <canvas id="fg-canvas" style="position: absolute; top: 0; left: 0; pointer-events: none; z-index: 20; opacity: 1;"></canvas>
                <div id="recolor-container" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 30; pointer-events: none; mask-size: 100% 100%; -webkit-mask-size: 100% 100%;">
                    <canvas id="recolor-canvas"></canvas>
                </div>
                <div id="eraser-interaction" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 40; pointer-events: none;"></div>
            </div>
            <div id="adv-info-bar" class="canvas-info-bar">
                <span id="ai-size">Mat size: —</span>
                <span id="ai-dpi">Image DPI: —</span>
                <span><span class="info-red">Red area:</span> Bleed — cut off during production</span>
                <span><span class="info-yellow">Yellow area:</span> Safe Zone — Keep essential items out of this zone.</span>
            </div>
        </div>
    </div>
    <div class="version-tag" style="color:rgba(255,255,255,0.2); z-index:10001;">v1.7.1</div>
    </div><!-- /#adv-backdrop -->
</div>
</div><!-- /#designer-visibility-wrapper -->

<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"
        integrity="sha512-CeIsOAsgJnmevfCi2C6/3QMBlmN7n4JnkFjzFBCZm1G9yFZSFKuBBM/zKWMW5Qa7zJGNFBr/BpC98/A8dHEg=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>

{%- comment %}
  The main editor JS is loaded after Fabric.js and after the bootstrap has had
  a chance to fire the 'playmat:config-ready' event. The editor JS reads
  window.PLAYMAT_* overrides (set by the bootstrap) before falling back to
  its own built-in constants, so app-admin settings take effect without a
  theme deployment.
{%- endcomment %}
{{ 'playmat-designer.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Playmat Designer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "app_url",
      "label": "App Backend URL",
      "info": "Your Railway app URL (e.g. https://playmat-studio.railway.app). Leave blank to use built-in defaults. Set once at install — no need to change per-product.",
      "placeholder": "https://your-app.railway.app"
    },
    {
      "type": "select",
      "id": "mat_size",
      "label": "Mat Size (fallback)",
      "info": "Used only if this product ID is not in the app's Product→Size map. Standard = 24.5\" x 14.5\", Extended = 28.5\" x 14.5\".",
      "options": [
        { "value": "standard", "label": "Standard (24.5\" x 14.5\")" },
        { "value": "extended", "label": "Extended (28.5\" x 14.5\")" }
      ],
      "default": "standard"
    },
    {
      "type": "text",
      "id": "trigger_variant",
      "label": "Show only for variant (Option 1 text)",
      "info": "Leave blank to always show the designer. Enter the exact Option 1 value (e.g. 'Custom Artwork') to only show when that variant is selected. Case-insensitive.",
      "placeholder": "e.g. Custom Artwork"
    },
    {
      "type": "range",
      "id": "landing_padding",
      "label": "Button area top/bottom padding (px)",
      "min": 0,
      "max": 80,
      "step": 2,
      "default": 10
    },
    {
      "type": "text",
      "id": "size_variant_keyword",
      "label": "Extended mat variant keyword",
      "info": "If this product has both Standard and Extended variants, enter a keyword from the Extended variant title (e.g. '28' or 'Extended'). Leave blank if single-size."
    }
  ]
}
{% endschema %}
