# Shopify App credentials — from your Partner Dashboard
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Set to your Railway deployment URL (no trailing slash)
HOST=https://your-app.railway.app

# Node environment
NODE_ENV=production

# Scopes the app requests
SCOPES=read_orders,write_orders,read_products,write_script_tags,read_customers

# Cloudflare Worker URLs (configurable per-store in admin, but set defaults here)
DEFAULT_CLOUDFLARE_UPLOAD_URL=https://playmat-r2-upload.salve.workers.dev/
DEFAULT_CLOUDFLARE_WORKER_URL=https://playmat-upscaler.salve.workers.dev
DEFAULT_CLOUDFLARE_BG_WORKER_URL=https://playmat-removebg.salve.workers.dev/
# Hosting URL for the Share / Get Printed flow (returns a 7-day public link)
DEFAULT_CLOUDFLARE_HOST_URL=https://files.playmatstudio.com/
