# ── Shopify App Credentials ───────────────────────────────────────────────────
# Get these from Shopify Partners → App → API credentials
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# ── Deployment URL ────────────────────────────────────────────────────────────
# Your Railway app URL — no trailing slash. Set after first Railway deploy.
HOST=https://your-app.railway.app

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Supabase → Project Settings → Database → URI (Connection string)
# Required for production. Without this, sessions are lost on every restart.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
SCOPES=read_orders,write_orders,read_products,write_script_tags,read_customers

# ── Cloudflare Worker URLs ────────────────────────────────────────────────────
# These are the built-in defaults. Only override if you deploy your own Workers.
DEFAULT_CLOUDFLARE_UPLOAD_URL=https://playmat-r2-upload.salve.workers.dev/
DEFAULT_CLOUDFLARE_WORKER_URL=https://playmat-upscaler.salve.workers.dev
DEFAULT_CLOUDFLARE_BG_WORKER_URL=https://playmat-removebg.salve.workers.dev/
DEFAULT_CLOUDFLARE_HOST_URL=https://files.playmatstudio.com/
